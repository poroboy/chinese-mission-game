rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function owns(uid) { return signedIn() && request.auth.uid == uid; }

    match /lessons/{lessonId} {
      allow read: if signedIn() && resource.data.isActive == true;
      allow write: if false;
      match /vocab/{wordId} {
        allow read: if signedIn();
        allow write: if false;
      }
    }

    match /users/{uid} {
      allow create: if owns(uid)
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.totalScore == 1000;
      allow read, update, delete: if owns(uid);

      match /{subcollection}/{document=**} {
        allow read, write: if owns(uid);
      }
    }
  }
}
